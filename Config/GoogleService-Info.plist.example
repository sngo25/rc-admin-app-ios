<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_API_KEY</string>
	<key>BUNDLE_ID</key>
	<string>app.cvnl.CVNLAdmin</string>
	<key>GCM_SENDER_ID</key>
	<string>YOUR_GCM_SENDER_ID</string>
	<key>GOOGLE_APP_ID</key>
	<string>1:YOUR_GCM_SENDER_ID:ios:YOUR_APP_ID</string>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>PROJECT_ID</key>
	<string>your-admin-firebase-project-id</string>
	<key>STORAGE_BUCKET</key>
	<string>your-admin-firebase-project-id.appspot.com</string>
</dict>
</plist>
